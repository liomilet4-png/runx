{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.runx.ai/runx/send-as/plan/v1.json",
  "x-runx-packet-id": "runx.send_as.plan.v1",
  "$defs": {
    "sendPlan": {
      "type": "object",
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["ready", "needs_input", "denied", "refused"]
        },
        "action_family": { "const": "send-as" },
        "principal": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["user", "team", "account", "service"]
            },
            "ref": { "type": "string", "minLength": 1 }
          },
          "required": ["type", "ref"],
          "additionalProperties": false
        },
        "provider": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "account_ref": { "type": "string" },
            "runtime_path": { "type": "string" }
          },
          "required": ["name", "account_ref", "runtime_path"],
          "additionalProperties": false
        },
        "send_class": {
          "type": "string",
          "enum": ["transactional", "campaign", "flow_step", "support_reply", "outreach", "status", "internal"]
        },
        "channel": {
          "type": "string",
          "enum": ["email", "sms", "chat", "push", "webhook", "other"]
        },
        "audience": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["recipient", "list", "segment", "thread", "channel", "all_contacts"]
            },
            "ref": { "type": "string" },
            "requires_reconfirmation": { "type": "boolean" }
          },
          "required": ["type", "ref", "requires_reconfirmation"],
          "additionalProperties": false
        },
        "content": {
          "type": "object",
          "properties": {
            "draft_ref": { "type": "string" },
            "digest": { "type": "string" },
            "subject_or_title": { "type": "string" }
          },
          "required": ["draft_ref", "digest", "subject_or_title"],
          "additionalProperties": false
        },
        "gates": {
          "type": "object",
          "properties": {
            "preflight_required": { "type": "boolean" },
            "human_approval_required": { "type": "boolean" },
            "approval_ref": { "type": "string" }
          },
          "required": ["preflight_required", "human_approval_required", "approval_ref"],
          "additionalProperties": false
        },
        "blockers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "provider_actions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "success_checkpoint": {
          "type": "object",
          "properties": {
            "milestone": { "type": "string", "minLength": 1 },
            "description": { "type": "string", "minLength": 1 }
          },
          "required": ["milestone", "description"],
          "additionalProperties": false
        }
      },
      "required": [
        "decision",
        "action_family",
        "principal",
        "provider",
        "send_class",
        "channel",
        "audience",
        "content",
        "gates",
        "blockers",
        "provider_actions",
        "evidence_refs",
        "success_checkpoint"
      ],
      "allOf": [
        {
          "if": {
            "properties": { "decision": { "const": "ready" } },
            "required": ["decision"]
          },
          "then": {
            "properties": {
              "provider": {
                "properties": {
                  "name": { "minLength": 1 },
                  "account_ref": { "minLength": 1 },
                  "runtime_path": { "minLength": 1 }
                }
              },
              "audience": {
                "properties": { "ref": { "minLength": 1 } }
              },
              "content": {
                "properties": {
                  "draft_ref": { "minLength": 1 },
                  "digest": { "pattern": "^sha256:[0-9a-f]{64}$" }
                }
              },
              "provider_actions": { "minItems": 1 }
            }
          }
        }
      ],
      "additionalProperties": false
    }
  },
  "allOf": [
    { "$ref": "#/$defs/sendPlan" }
  ],
  "properties": {
    "data": { "$ref": "#/$defs/sendPlan" }
  },
  "additionalProperties": true
}
