{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.runx.ai/runx/github-sync/v1.json",
  "x-runx-packet-id": "runx.github_sync.v1",
  "type": "object",
  "properties": {
    "decision": {
      "type": "string",
      "enum": ["ready", "blocked", "refused", "needs_agent"]
    },
    "repo": { "type": "string", "minLength": 1 },
    "direction": {
      "type": "string",
      "enum": ["pull", "push"]
    },
    "resources_touched": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "diff_summary": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "scope_used": { "type": "string", "minLength": 1 },
    "gates": { "type": "object", "additionalProperties": true },
    "blockers": { "type": "array", "items": { "type": "string" } }
  },
  "required": [
    "decision",
    "repo",
    "direction",
    "resources_touched",
    "diff_summary",
    "scope_used",
    "gates",
    "blockers"
  ],
  "additionalProperties": false
}
